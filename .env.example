# ──────────────────────────────────────────────────────────────────────────────
# Admin editor env vars (no Supabase).
# Local dev: copy this file to `.env` and fill in real values.
# Vercel: set the same vars in Project Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────────

# A password you choose — the only credential to sign into /admin.
ADMIN_PASSWORD=change-me

# Any long random string — signs the admin session cookie.
# Generate one with: openssl rand -base64 48
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# GitHub fine-grained PAT with "Contents: Read and write" on the repo below.
# Create at https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=github_pat_xxx
GITHUB_REPO=dragonofdeseret/daodezion-site

# Branch the editor commits to. Use astro-migration while iterating; main once live.
GITHUB_BRANCH=astro-migration
