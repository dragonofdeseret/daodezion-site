---
import BaseLayout from '../layouts/BaseLayout.astro'
// DRAKOSOPHIA — the hidden door. Unlisted (noindex), no site chrome, reached
// only from the faint eye-mark in the footers.
//
// NOTE: the passphrase below lives in client-side code, so it is a *threshold*,
// not a vault — anyone who views source can read it. For true secrecy, gate the
// inner content behind a server or move it to an unguessable unlisted URL.
---
<BaseLayout title="·" appendSiteName={false} chrome={false} noindex={true} bodyClass="drako">
  <main class="drako-shell">
    <span class="drako-sigil" aria-hidden="true">
      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img">
        <circle class="ds-ring" cx="100" cy="100" r="80" />
        <circle class="ds-spark" cx="100" cy="20" r="5" />
        <path class="ds-eye" d="M55,100 Q100,68 145,100 Q100,132 55,100 Z" />
        <ellipse class="ds-pupil" cx="100" cy="100" rx="5" ry="18" />
      </svg>
    </span>

    <h1>Drakosophia</h1>
    <p class="drako-epigraph">
      The beast of beasts does not guard mere treasure—such frivolous behavior that would be.<br />
      A dragon guards the pearl of enlightenment.<br />
      If you slay the dragon to get to the treasure, you forgo the very knowledge of the true value of the treasure.
    </p>

    <form class="drako-gate" id="drako-gate" autocomplete="off">
      <input
        type="password"
        id="drako-word"
        name="word"
        placeholder="The word"
        aria-label="Passphrase"
        spellcheck="false"
      />
      <button type="submit">Enter</button>
    </form>
    <p class="drako-deny" id="drako-deny" role="status" aria-live="polite"></p>

    <div class="drako-inner" id="drako-inner" hidden>
      <div class="ornament"><span class="lozenge">❖</span></div>
      <p class="drako-chamber-intro">
        You have crossed the threshold. What follows is only the bare frame of the
        work—to be filled in time, in person, and in trust.
      </p>

      <h2 class="drako-chamber-title">The Three Lights</h2>
      <div class="drako-lights">
        <article class="drako-light">
          <span class="gem" aria-hidden="true"></span>
          <span class="light-glyph" aria-hidden="true">明珠</span>
          <h3>The Pearl</h3>
          <p>The luminous pearl—awareness recovered; the light one was already carrying.</p>
        </article>
        <article class="drako-light">
          <span class="gem" aria-hidden="true"></span>
          <span class="light-glyph" aria-hidden="true">金華</span>
          <h3>The Golden Flower</h3>
          <p>The circulation of the light; the flowering of a cultivated spirit.</p>
        </article>
        <article class="drako-light">
          <span class="gem" aria-hidden="true"></span>
          <span class="light-glyph" aria-hidden="true">白石</span>
          <h3>The White Stone</h3>
          <p>The white stone, and the new name written on it—known only to the one who receives it.</p>
        </article>
      </div>

      <h2 class="drako-chamber-title">The Work</h2>
      <ul class="drako-mysteries">
        <li>Degrees of the chamber and their tokens — <em>to be written.</em></li>
        <li>The reading behind the reading: esoteric commentary on the three paths — <em>to be written.</em></li>
        <li>Rites, oaths, and the keeping of the inner register — <em>to be written.</em></li>
      </ul>
    </div>

    <a class="drako-back" href="/">Return</a>
  </main>

  <script is:inline>
    (function () {
      // Threshold word. Change this to your chosen passphrase (kept lowercase here).
      var PASSPHRASE = 'ouroboros'

      var form = document.getElementById('drako-gate')
      var input = document.getElementById('drako-word')
      var deny = document.getElementById('drako-deny')
      var inner = document.getElementById('drako-inner')

      form.addEventListener('submit', function (event) {
        event.preventDefault()
        var word = (input.value || '').trim().toLowerCase()
        if (word === PASSPHRASE) {
          form.setAttribute('hidden', '')
          deny.textContent = ''
          inner.removeAttribute('hidden')
        } else {
          deny.textContent = 'The door does not know that word.'
          input.value = ''
          input.focus()
        }
      })
    })()
  </script>
</BaseLayout>
