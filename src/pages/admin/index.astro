---
export const prerender = false
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getCollection } from 'astro:content'

const sessions = await getCollection('sessions')
---
<AdminLayout title="Dashboard">
  <h1>Admin</h1>
  <ul class="admin-cards">
    <li>
      <a href="/admin/sessions">
        <strong>Lodge Sessions</strong>
        <span>{sessions.length} record{sessions.length === 1 ? '' : 's'} · add &amp; edit proceedings</span>
      </a>
    </li>
    <li>
      <a href="/admin/upcoming">
        <strong>Upcoming Session</strong>
        <span>Schedule (or clear) the event &amp; RSVP shown on the Lodge page</span>
      </a>
    </li>
    <li>
      <a href="/admin/library">
        <strong>Library</strong>
        <span>Add &amp; edit the texts across the three paths</span>
      </a>
    </li>
  </ul>
</AdminLayout>
