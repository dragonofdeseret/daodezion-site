---
export const prerender = false
import AdminLayout from '../../layouts/AdminLayout.astro'

const next = Astro.url.searchParams.get('next') || '/admin'
const hasError = Astro.url.searchParams.has('error')
---
<AdminLayout title="Sign in">
  <section class="admin-login">
    <h1>Enter</h1>
    {hasError && <p class="admin-error">Incorrect password.</p>}
    <form method="POST" action="/admin/api/login">
      <input type="hidden" name="next" value={next} />
      <label>
        Password
        <input type="password" name="password" autocomplete="current-password" autofocus required />
      </label>
      <button type="submit" class="button">Sign in</button>
    </form>
  </section>
</AdminLayout>
