---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection, render } from 'astro:content'

// Build the meeting register from the `sessions` collection. Records are
// numbered LOZ-{year}-{NNN} within each year (ascending by date); years are
// shown most-recent first.
const all = await getCollection('sessions')
const sorted = [...all].sort((a, b) => a.data.date.localeCompare(b.data.date))

const byYear = new Map<number, typeof sorted>()
for (const entry of sorted) {
  const year = Number(entry.data.date.slice(0, 4))
  if (!byYear.has(year)) byYear.set(year, [])
  byYear.get(year)!.push(entry)
}

const years = [...byYear.keys()].sort((a, b) => b - a)
const pad3 = (n: number) => String(n).padStart(3, '0')
const formatDate = (iso: string) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(
    new Date(`${iso}T12:00:00`),
  )

const yearGroups = []
for (const year of years) {
  const entries = byYear.get(year)!
  const rendered = []
  for (let i = 0; i < entries.length; i++) {
    const entry = entries[i]
    const { Content } = await render(entry)
    rendered.push({
      entry,
      Content,
      recordNo: `LOZ-${year}-${pad3(i + 1)}`,
      dateLong: formatDate(entry.data.date),
    })
  }
  yearGroups.push({ year, rendered })
}

const totalRecords = sorted.length
const currentYear = years[0] ?? new Date().getFullYear()
---
<BaseLayout
  title="Lodge of Zion"
  description="The Lodge of Zion: the gathering body of Dao De Zion Institute. Sessions, announcements, and archived proceedings, convened by its founding chapter, The Holy Smoke."
  active="lodge"
>
  <section class="hero compact ink-hero">
    <p class="eyebrow">The gathering body · sessions · proceedings</p>
    <h1>Lodge of Zion</h1>
    <p class="lede lede-strong">
      The Lodge is where the Institute becomes a people rather than a syllabus—a recurring
      assembly for study, argument, and the slow accumulation of a shared mind. What is
      said is kept; the register is the Lodge's memory of itself.
    </p>
  </section>

  <section class="statement-block compact-block">
    <p>
      We have been told that if we stop seeking we shall not only find no more but lose the
      treasures we already have.
      <br />— Hugh Nibley
    </p>
  </section>

  <section class="holy-smoke ink-frame">
    <p class="eyebrow">The founding chapter</p>
    <h2>The Holy Smoke</h2>
    <p>
      Before the Lodge had a name, there was a circle of friends who simply gathered—to
      read, to argue, to laugh, to keep faith with one another and with the questions. They
      called themselves <strong>The Holy Smoke</strong>, and they remain the hearth at which
      the Lodge of Zion convenes: its first chapter, and the living proof that this is
      fellowship before it is an institution.
    </p>
  </section>

  <section class="split-section">
    <div data-lodge-upcoming></div>

    <article class="card event-card record-standard-card ink-card">
      <p class="eyebrow">About the Lodge</p>
      <div class="archive-notes archive-notes-recorded">
        <p>
          The Lodge of Zion is the gathering body of Dao De Zion Institute — its recurring
          forum for study sessions, round-tables, and recorded proceedings. It is not a
          sequence of isolated events, but an accumulating conversation in which each
          meeting inherits the weight and direction of those that came before it.
        </p>
        <p>
          Its founding chapter, The Holy Smoke, is the living hearth where the Lodge
          actually convenes. Accordingly the Lodge is maintained as a register rather than a
          feed: what occurs is recorded, returned to, and allowed to condition the shape of
          future meetings. The archive is not supplementary; it is constitutive.
        </p>
        <p>Attendance is limited and requires registration.</p>
      </div>
    </article>
  </section>

  <section class="archive-section">
    <div class="section-heading">
      <h2>Meeting Register</h2>
      <p>Archive · Record of Proceedings</p>
    </div>

    <div class="register-index card ink-card">
      <p class="eyebrow">Index</p>
      <div class="register-index-grid">
        <p><strong>Series</strong><span>Lodge of Zion Proceedings</span></p>
        <p><strong>Current year</strong><span>{currentYear}</span></p>
        <p><strong>Records entered</strong><span>{totalRecords}</span></p>
        <p><strong>Status</strong><span>Active</span></p>
      </div>
    </div>

    {years.length > 1 && (
      <div class="register-index card ink-card" style="margin-bottom: 1rem;">
        <p class="eyebrow">Years</p>
        <div class="button-row" style="padding-top: 0;">
          {years.map((y) => (
            <a class="button" href={`#lodge-year-${y}`} style="margin-right: 0.55rem; margin-bottom: 0.55rem;">{y}</a>
          ))}
        </div>
      </div>
    )}

    {yearGroups.map(({ year, rendered }) => (
      <section class="archive-year" id={`lodge-year-${year}`}>
        <div class="archive-year-heading">
          <p class="archive-year-label">Register Year</p>
          <h3>{year}</h3>
        </div>
        {rendered.map(({ entry, Content, recordNo, dateLong }) => (
          <article class="archive-entry recorded-entry ink-card">
            <div class="archive-meta archive-meta-formal">
              <p><strong>Record no.</strong><span>{recordNo}</span></p>
              <p><strong>Date</strong><span>{dateLong}</span></p>
              <p><strong>Location</strong><span>{entry.data.location}</span></p>
              <p><strong>Attendees</strong><span>{entry.data.attendees}</span></p>
              <p><strong>Topic</strong><span>{entry.data.topic}</span></p>
              <p><strong>Filed</strong><span>{entry.data.filed}</span></p>
            </div>
            <div class="archive-notes archive-notes-recorded">
              <div class="record-heading">
                <p class="record-type">Proceedings</p>
                <h3>Minutes / Notes</h3>
              </div>
              <Content />
            </div>
          </article>
        ))}
      </section>
    ))}
  </section>

  <script is:inline src="/lodge-register.js"></script>
</BaseLayout>
