---
import '../styles/global.css'
import '../styles/admin.css'
interface Props {
  title: string
}
const { title } = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · Admin · Dao De Zion</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="admin">
    <header class="admin-header">
      <a class="admin-brand" href="/admin">Dao De Zion · Admin</a>
      <nav class="admin-nav">
        <a href="/admin/sessions">Sessions</a>
        <a href="/admin/sign-out">Sign out</a>
      </nav>
    </header>
    <main class="admin-main">
      <slot />
    </main>
  </body>
</html>
