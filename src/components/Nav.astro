---
// Primary site header + nav. `active` drives the top-level highlight;
// `sub` highlights the active Library path. The Library dropdown reveals on
// hover only within the Library section (see body.library-active in global.css).
interface Props {
  active?: 'home' | 'library' | 'lodge'
  sub?: 'dao' | 'de' | 'zion'
}
const { active, sub } = Astro.props
const inLibrary = active === 'library'
---
<header class="site-header">
  <div class="brand-row">
    <a class="brand" href="/">Dao De Zion Institute</a>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">Menu</button>
  </div>
  <nav id="site-nav" class="site-nav" aria-label="Primary">
    <a class={active === 'home' ? 'active' : undefined} href="/">Home</a>
    <div class={inLibrary ? 'nav-dropdown current' : 'nav-dropdown'}>
      <a class={inLibrary ? 'nav-drop-link active' : 'nav-drop-link'} href="/library">Library</a>
      <div class="nav-drop-menu" aria-label="Library pages">
        <a class={sub === 'dao' ? 'active' : undefined} href="/dao">Dao</a>
        <a class={sub === 'de' ? 'active' : undefined} href="/de">De</a>
        <a class={sub === 'zion' ? 'active' : undefined} href="/zion">Zion</a>
      </div>
    </div>
    <a class={active === 'lodge' ? 'active' : undefined} href="/lodge">Lodge of Zion</a>
  </nav>
</header>
