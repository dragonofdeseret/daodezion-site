---
// Central emblem: round heaven / square earth (天圆地方, also the Masonic
// compass + square) enclosing a stepped temple-mountain. An arched doorway —
// the veil / threshold — sits at its base; the world-axis rises through the
// open temple to a radiant star. Three tiers = Dao / De / Zion. Decorative.
---
<span class="emblem" aria-hidden="true">
  <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img">
    <!-- heaven (round) -->
    <circle class="em-heaven" cx="100" cy="100" r="92" />
    <circle class="em-heaven-2" cx="100" cy="100" r="86" />
    <!-- earth (square) -->
    <rect class="em-earth" x="46" y="46" width="108" height="108" />
    <line class="em-horizon" x1="24" y1="152" x2="176" y2="152" />
    <!-- world-axis, behind the open temple -->
    <line class="em-axis" x1="100" y1="152" x2="100" y2="52" />
    <!-- stepped temple-mountain -->
    <path class="em-mount" d="M58,152 L142,152 L132,130 L68,130 Z" />
    <path class="em-mount" d="M72,130 L128,130 L119,108 L81,108 Z" />
    <path class="em-mount" d="M84,108 L116,108 L109,88 L91,88 Z" />
    <!-- the gate / veil -->
    <path class="em-gate" d="M94,152 L94,140 Q100,132 106,140 L106,152" />
    <!-- radiant star -->
    <circle class="em-halo" cx="100" cy="48" r="13" />
    <path class="em-star" d="M100,32 L102.5,45.5 L114,48 L102.5,50.5 L100,64 L97.5,50.5 L86,48 L97.5,45.5 Z" />
    <circle class="em-core" cx="100" cy="48" r="2.4" />
  </svg>
</span>
