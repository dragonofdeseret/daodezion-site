---
// Renders a single path page (Dao / De / Zion) from a path object in
// src/data/paths.js. Used by the three path pages so they stay in sync.
interface Book {
  slug: string
  title: string
  note: string
  href: string
  why?: string
}
interface Path {
  slug: string
  name: string
  subtitle: string
  glyph: string
  sancai: string
  lede: string
  statement: string
  why: string
  core: Book[]
  further: Book[]
}
interface Props {
  path: Path
}
const { path } = Astro.props
---
<section class="hero compact ink-hero">
  <span class="title-glyph" aria-hidden="true">{path.glyph}</span>
  <p class="eyebrow">Institute library</p>
  <h1>{path.name}</h1>
  <p class="path-subtitle large">{path.subtitle}</p>
  <p class="sancai">{path.sancai}</p>
  <p class="lede lede-strong">{path.lede}</p>
</section>

<section class="statement-block compact-block">
  <p>{path.statement}</p>
</section>

<p class="archive-intro-note">{path.name.toUpperCase()} — {path.subtitle.toUpperCase()}</p>

<section class="reading-columns">
  <article class="card ink-card">
    <h2>Core Texts</h2>
    <div class="book-grid">
      {path.core.map((book) => (
        <div class="book-item">
          <a href={`/${path.slug}/${book.slug}`} class="book-link book-link-primary">{book.title}</a>
          <p class="book-note">{book.note}</p>
          {book.why && (
            <details class="book-why">
              <summary>Why it belongs</summary>
              <p>{book.why}</p>
            </details>
          )}
        </div>
      ))}
    </div>
  </article>

  <article class="card ink-card">
    <h2>Further Light and Knowledge</h2>
    <div class="book-grid">
      {path.further.map((book) => (
        <div class="book-item">
          <a href={`/${path.slug}/${book.slug}`} class="book-link book-link-secondary">{book.title}</a>
          <p class="book-note">{book.note}</p>
          {book.why && (
            <details class="book-why">
              <summary>Why it belongs</summary>
              <p>{book.why}</p>
            </details>
          )}
        </div>
      ))}
    </div>
  </article>
</section>

<section class="note-block framed-note ink-frame">
  <h2>Why these texts belong here</h2>
  <p>{path.why}</p>
</section>
