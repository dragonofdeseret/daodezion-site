---
interface Echo {
  path: string
  slug: string
  title: string
  note: string
}
interface Fields {
  path: string
  tier: string
  slug: string
  title: string
  note: string
  href: string
  epithet: string
  quoteText: string
  quoteCite: string
  why: string
  echoes: Echo[]
}
interface TextRef {
  path: string
  slug: string
  title: string
}
interface Props {
  isNew: boolean
  fields?: Fields
  allTexts: TextRef[]
}
const { isNew, fields, allTexts } = Astro.props
const f: Fields = fields ?? {
  path: 'dao',
  tier: 'core',
  slug: '',
  title: '',
  note: '',
  href: '',
  epithet: '',
  quoteText: '',
  quoteCite: '',
  why: '',
  echoes: [],
}
const PATHS = ['dao', 'de', 'zion']
---
<form class="admin-form" id="library-form" data-is-new={String(isNew)} data-orig-slug={f.slug}>
  <div class="admin-grid-2">
    <label>Path
      <select id="lf-path">
        {PATHS.map((p) => <option value={p} selected={p === f.path}>{p}</option>)}
      </select>
    </label>
    <label>Section
      <select id="lf-tier">
        <option value="core" selected={f.tier === 'core'}>Core Texts</option>
        <option value="further" selected={f.tier === 'further'}>Further Light and Knowledge</option>
      </select>
    </label>
  </div>

  <label>Slug (URL segment)
    <input id="lf-slug" type="text" value={f.slug} readonly={!isNew} placeholder="auto from title if blank" />
  </label>
  <label>Title<input id="lf-title" type="text" value={f.title} required /></label>
  <label>Edition / note<input id="lf-note" type="text" value={f.note} /></label>
  <label>Link (href)<input id="lf-href" type="url" value={f.href} placeholder="purchase or read link — optional" /></label>
  <label>Epithet<input id="lf-epithet" type="text" value={f.epithet} placeholder="short emblem-phrase — optional" /></label>

  <div class="admin-grid-2">
    <label>Quote<input id="lf-quoteText" type="text" value={f.quoteText} placeholder="a key passage — optional" /></label>
    <label>Citation<input id="lf-quoteCite" type="text" value={f.quoteCite} placeholder="source — optional" /></label>
  </div>

  <label>Why it belongs (Markdown)<textarea id="lf-why" rows="6">{f.why}</textarea></label>
  <details class="admin-preview"><summary>Preview</summary><div class="admin-preview-body" id="lf-why-preview"></div></details>

  <fieldset class="admin-echoes">
    <legend>Echoes — cross-links to other texts</legend>
    <div id="lf-echoes-rows">
      {f.echoes.map((e) => (
        <div class="echo-row">
          <select class="echo-target">
            <option value="">— choose a text —</option>
            {allTexts.map((t) => (
              <option value={`${t.path}|${t.slug}`} data-title={t.title} selected={t.path === e.path && t.slug === e.slug}>
                {t.path} / {t.title}
              </option>
            ))}
          </select>
          <input class="echo-note" type="text" value={e.note} placeholder="the resonance — how they rhyme" />
          <button type="button" class="echo-remove" aria-label="Remove echo">×</button>
        </div>
      ))}
    </div>
    <button type="button" class="button admin-add-echo" id="lf-add-echo">+ Add echo</button>
    <template id="echo-row-template">
      <div class="echo-row">
        <select class="echo-target">
          <option value="">— choose a text —</option>
          {allTexts.map((t) => (
            <option value={`${t.path}|${t.slug}`} data-title={t.title}>{t.path} / {t.title}</option>
          ))}
        </select>
        <input class="echo-note" type="text" placeholder="the resonance — how they rhyme" />
        <button type="button" class="echo-remove" aria-label="Remove echo">×</button>
      </div>
    </template>
  </fieldset>

  <div class="admin-form-actions">
    <button type="submit" class="button" id="lf-save">Save</button>
    {!isNew && <button type="button" class="button admin-danger" id="lf-delete">Delete</button>}
    {!isNew && <a class="admin-cancel" href={`/${f.path}/${f.slug}`} target="_blank" rel="noopener noreferrer">View on site ↗</a>}
    <a class="admin-cancel" href="/admin/library">Cancel</a>
  </div>
  <p class="admin-status" id="lf-status" role="status" aria-live="polite"></p>
</form>

<script>
  import { marked } from 'marked'

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement
  const form = document.getElementById('library-form') as HTMLFormElement
  const statusEl = document.getElementById('lf-status') as HTMLElement
  const saveBtn = $('lf-save')
  const isNew = form.dataset.isNew === 'true'
  const origSlug = form.dataset.origSlug || ''
  const set = (m: string) => {
    statusEl.textContent = m
  }
  const kebab = (s: string) =>
    s.toLowerCase().normalize('NFKD').replace(/[^\w\s-]/g, '').trim().replace(/\s+/g, '-').replace(/-+/g, '-').slice(0, 48).replace(/^-+|-+$/g, '')

  // Markdown preview
  const why = $('lf-why')
  const preview = document.getElementById('lf-why-preview') as HTMLElement
  const renderPreview = () => {
    preview.innerHTML = marked.parse(why.value || '*(nothing yet)*') as string
  }
  why.addEventListener('input', renderPreview)
  renderPreview()

  // Echoes — add/remove rows
  const rows = document.getElementById('lf-echoes-rows') as HTMLElement
  const template = document.getElementById('echo-row-template') as HTMLTemplateElement
  document.getElementById('lf-add-echo')!.addEventListener('click', () => {
    rows.appendChild(template.content.cloneNode(true))
  })
  rows.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.echo-remove')
    if (btn) btn.closest('.echo-row')?.remove()
  })
  const gatherEchoes = () => {
    const out: { path: string; slug: string; title: string; note: string }[] = []
    rows.querySelectorAll('.echo-row').forEach((row) => {
      const sel = row.querySelector('.echo-target') as HTMLSelectElement
      const note = (row.querySelector('.echo-note') as HTMLInputElement).value.trim()
      if (!sel.value) return
      const [path, slug] = sel.value.split('|')
      const title = sel.options[sel.selectedIndex]?.dataset.title || ''
      out.push({ path, slug, title, note })
    })
    return out
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault()
    saveBtn.disabled = true
    set('Saving…')
    let slug = $('lf-slug').value.trim()
    if (isNew && !slug) slug = kebab($('lf-title').value)
    const payload = {
      isNew,
      originalSlug: origSlug,
      path: $('lf-path').value,
      tier: $('lf-tier').value,
      slug,
      title: $('lf-title').value,
      note: $('lf-note').value,
      href: $('lf-href').value,
      epithet: $('lf-epithet').value,
      quoteText: $('lf-quoteText').value,
      quoteCite: $('lf-quoteCite').value,
      why: why.value,
      echoes: JSON.stringify(gatherEchoes()),
    }
    try {
      const res = await fetch('/admin/api/save-library', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      })
      const data = await res.json()
      if (!res.ok) throw new Error(data.error || 'Save failed')
      set('Saved — rebuilds in ~30–60s. Returning to the list…')
      setTimeout(() => {
        window.location.href = '/admin/library'
      }, 1400)
    } catch (err) {
      set('Error: ' + (err instanceof Error ? err.message : String(err)))
      saveBtn.disabled = false
    }
  })

  const del = document.getElementById('lf-delete')
  if (del) {
    del.addEventListener('click', async () => {
      if (!window.confirm('Delete this text? This commits a removal to the repo.')) return
      set('Deleting…')
      try {
        const res = await fetch('/admin/api/delete-library', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ slug: origSlug }),
        })
        const data = await res.json()
        if (!res.ok) throw new Error(data.error || 'Delete failed')
        set('Deleted. Returning…')
        setTimeout(() => {
          window.location.href = '/admin/library'
        }, 1200)
      } catch (err) {
        set('Error: ' + (err instanceof Error ? err.message : String(err)))
      }
    })
  }
</script>
